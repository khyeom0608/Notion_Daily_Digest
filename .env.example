# Notion integration token (ntn_ prefix, 약 50자)
# 발급: Notion → Settings → Connections → "New integration" → Internal
# 알림 대상 페이지마다 Connections로 이 integration을 연결해야 봇이 페이지를 읽을 수 있음
NOTION_API_KEY=여기에_본인_노션_integration_토큰

# Google Gemini API key (free tier OK)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_본인_Gemini_API_KEY

# Slack Incoming Webhook URL (채널 1개 전용)
# 발급: api.slack.com/apps → Create New App → Incoming Webhooks → Add to Workspace
# 형식: hooks.slack.com/services/<TEAM>/<BOT>/<TOKEN>
SLACK_WEBHOOK_URL=여기에_본인_Slack_Webhook_URL

# (선택) 참고용 채널 ID — 코드에선 사용 안 함
SLACK_CHANNEL_ID=여기에_본인_Slack_채널_ID
