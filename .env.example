# Notion integration token (ntn_ prefix, ~50 chars)
# Create at: Notion → Settings → Connections → "New integration" → Internal
# Each page you want to monitor must have this integration added via Connections.
NOTION_API_KEY=YOUR_NOTION_INTEGRATION_TOKEN

# Google Gemini API key (free tier is fine)
# Create at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Slack Incoming Webhook URL (bound to one channel)
# Create at: api.slack.com/apps → Create New App → Incoming Webhooks → Add to Workspace
# Format: hooks.slack.com/services/<TEAM>/<BOT>/<TOKEN>
SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL

# (Optional) Channel ID for reference only — not read by the script
SLACK_CHANNEL_ID=YOUR_SLACK_CHANNEL_ID
